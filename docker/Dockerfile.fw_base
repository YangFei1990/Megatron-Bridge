# Build layer variables
# To install trtllm set FW_DEP_BUILDER=trtllm_builder, FW_BASE_FINAL=trtllm_install
# To exclude trtllm set FW_DEP_BUILDER=base, FW_BASE_FINAL=fw_toolkit_builder
ARG FW_DEP_BUILDER
ARG FW_BASE_FINAL

ARG NEMO_FW_BASE_IMAGE
FROM ${NEMO_FW_BASE_IMAGE} AS base

ENV NVIDIA_PRODUCT_NAME="NeMo Framework"
ENV PIP_NO_CACHE_DIR=1
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /opt

##############################################################################
##
## VLLM wheel
##
##############################################################################

FROM base AS vllm_wheel

ARG VLLM_VERSION
ARG MAX_JOBS=4
ENV VLLM_VERSION=$VLLM_VERSION

WORKDIR /src/vllm

# Build vllm
RUN git clone https://github.com/vllm-project/vllm.git . && \
    echo "Building vLLM version: $VLLM_VERSION" && \
    git checkout $VLLM_VERSION && \
    python use_existing_torch.py && \
    pip install -r requirements/build/cuda.txt && \
    pip wheel --no-deps --no-build-isolation -v .

##############################################################################
##
## Top layer of FW_BASE container
##
## When TRTLLM is re-installed, FW_DEP_BUILDER=trtllm_builder
## default, FW_DEP_BUILDER=base
##
##############################################################################

FROM ${FW_DEP_BUILDER} AS fw_dep_builder

##############################################################################
##
## UV setup and UV python configuration
##
## Setup ipykernel to use uv python
## Fix torchrun shebang to use uv python
##
##############################################################################

ARG UV_VERSION
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV UV_CACHE_DIR=/opt/uv_cache
ENV PATH="$UV_PROJECT_ENVIRONMENT/bin:$PATH"
ENV UV_LINK_MODE=copy
RUN curl -LsSf https://astral.sh/uv/${UV_VERSION}/install.sh | XDG_BIN_HOME=/usr/local/bin sh && \
    uv venv ${UV_PROJECT_ENVIRONMENT} --system-site-packages && \
    python -m ipykernel install --name=python3 --display-name="Python 3 (ipykernel)" && \
    if [ -f /usr/local/bin/torchrun ]; then \
    sed -i '1s|#!/usr/bin/python|#!/usr/bin/env python|' /usr/local/bin/torchrun; \
    fi

##############################################################################
##
## CUDA toolkit stage
##
##############################################################################

FROM fw_dep_builder AS fw_toolkit_builder

##############################################################################
##
## Reinstall CUDA toolkit packages
##
##############################################################################

ARG REINSTALL_NSYS
ARG NSYS_VERSION
ARG REINSTALL_CUDNN
ARG CUDNN_VERSION
ENV NSIGHT_SYSTEMS_VERSION $NSYS_VERSION
ARG REINSTALL_NCCL
ARG NCCL_VERSION
ARG REINSTALL_CUBLAS
ARG CUBLAS_VERSION

RUN --mount=type=bind,source=docker/common/install_nsys.sh,target=/opt/install_nsys.sh \
    --mount=type=bind,source=docker/common/install_cudnn.sh,target=/opt/install_cudnn.sh \
    --mount=type=bind,source=docker/common/install_nccl.sh,target=/opt/install_nccl.sh \
    --mount=type=bind,source=docker/common/install_cublas.sh,target=/opt/install_cublas.sh \
    if [ $REINSTALL_NSYS = "True" ]; then \
    bash /opt/install_nsys.sh --NSYS_VERSION=$NSYS_VERSION; \
    fi && \
    if [ $REINSTALL_CUDNN = "True" ]; then \
    bash /opt/install_cudnn.sh --CUDNN_VERSION=$CUDNN_VERSION --DEVEL; \
    fi && \
    if [ $REINSTALL_NCCL = "True" ]; then \
    bash /opt/install_nccl.sh --NCCL_VER=$NCCL_VERSION; \
    fi && \
    if [ $REINSTALL_CUBLAS = "True" ]; then \
    bash /opt/install_cublas.sh --CUBLAS_VER=$CUBLAS_VERSION; \
    fi

##############################################################################
##
## Install DeepEP and nvshmem
##
##############################################################################

ARG INSTALL_DEEPEP
ARG DEEPEP_COMMIT

ENV HYBRID_EP_MULTINODE=1
ENV RDMA_CORE_HOME=/opt/rdma-core/build
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64/:$LD_LIBRARY_PATH
RUN --mount=type=bind,source=docker/patches/deepep.patch,target=/opt/deepep.patch \
    if [ "$INSTALL_DEEPEP" = "True" ]; then \
    # Upgrade system rdma-core to v60; libibverbs-dev supplies the unversioned
    # libibverbs.so symlink required at link time.
    apt-get update && apt-get install -y --allow-change-held-packages \
        rdma-core libibverbs-dev && \
    apt-get clean && \
    ARCH_LIB=$(dpkg-architecture -qDEB_HOST_MULTIARCH) && \
    # libmlx5-dev is not available in the apt sources; create the unversioned
    # symlink from the versioned one as a fallback for the DeepEP build.
    test -f /usr/lib/${ARCH_LIB}/libmlx5.so || \
        ln -sf /usr/lib/${ARCH_LIB}/libmlx5.so.1 /usr/lib/${ARCH_LIB}/libmlx5.so && \
    # Expose the system install under RDMA_CORE_HOME so DeepEP setup.py finds
    # $RDMA_CORE_HOME/include and $RDMA_CORE_HOME/lib without a separate source build.
    mkdir -p ${RDMA_CORE_HOME} && \
    ln -sfn /usr/include ${RDMA_CORE_HOME}/include && \
    ln -sfn /usr/lib/${ARCH_LIB} ${RDMA_CORE_HOME}/lib && \
    git clone https://github.com/deepseek-ai/DeepEP.git && \
    pushd DeepEP && \
        git pull && \
        git fetch origin $DEEPEP_COMMIT && \
        git checkout FETCH_HEAD && \
        patch -p1 < /opt/deepep.patch && \
        pip install --no-cache-dir nvidia-nvshmem-cu13==3.4.5 && \
        # Create symlink for libnvshmem_host.so (required for DeepEP fabric handle operations)
        NVSHMEM_LIB_PATH=$(pip show nvidia-nvshmem-cu13 | grep "Location:" | cut -d' ' -f2)/nvidia/nvshmem/lib && \
        ln -sf ${NVSHMEM_LIB_PATH}/libnvshmem_host.so.3 ${NVSHMEM_LIB_PATH}/libnvshmem_host.so && \
        apt-get update && \
        apt-get install -y --no-install-recommends libnvidia-ml-dev && \
        TORCH_CUDA_ARCH_LIST="9.0 10.0 12.0" pip install --no-cache-dir --no-build-isolation -v . && \
        apt-get purge -y libnvidia-ml-dev && \
        apt-get autoremove -y && \
        rm -rf /var/lib/apt/lists/* && \
    popd; \
    fi

##############################################################################
##
## Install vLLM
##
##############################################################################

# Copy Wheels
RUN --mount=type=bind,from=vllm_wheel,source=/src/vllm/,target=/tmp/vllm/ \
    pip install /tmp/vllm/vllm*.whl && \
    pushd /usr/local/lib/python3.12/dist-packages/vllm && \
    popd

##############################################################################
##
## Final layer of FW_BASE container
##
## default, FW_BASE_FINAL=fw_toolkit_builder
##
##############################################################################

FROM ${FW_BASE_FINAL} AS nemo_fw_base_final

WORKDIR /opt
